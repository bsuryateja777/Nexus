# NEXUS Backend - Development Environment Template
# ============================================================================
# For local development: Copy to .env.local and fill in values
# Never commit secrets to .env - all credentials are in .env.local (gitignored)
# ============================================================================

# Backend Server Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=development

# Database (Entra ID token-based auth for Azure PostgreSQL)
DATABASE_URL=postgresql://nexusadmin@nexus-db-prod/nexus?sslmode=require

# Azure Services (non-sensitive names/endpoints only)
AZURE_STORAGE_ACCOUNT_NAME=sanexus
AZURE_SEARCH_SERVICE_NAME=search-nexus
AZURE_SEARCH_INDEX_NAME=multimodal-rag-1778597147966
AZURE_SEARCH_SEMANTIC_CONFIG=multimodal-rag-1778597147966-semantic-configuration
AZURE_SEARCH_SERVICELINKS_INDEX=rag-1778662331627
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://di-nexus.cognitiveservices.azure.com/

# Anthropic API Endpoint
ANTHROPIC_API_ENDPOINT=https://ais-sdc-playground.services.ai.azure.com/anthropic

# Knowledge Base
KB_STORAGE_PATH=/knowledge_base

# Azure AD Team Group (for role-based features)
AD_TEAM_GROUP_ID=09c77835-990a-471b-9354-11ff8ad7b520

# ============================================================================
# For local development setup, see .env.local (gitignored)
# ============================================================================